generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Article {
  id          String    @id @default(cuid())
  url         String    @unique
  title       String
  description String
  source      String
  category    String
  publishedAt DateTime
  fetchedAt   DateTime  @default(now())
  isPickedAt  DateTime?
  aiSummary   String?
  translated  Boolean   @default(false)

  @@index([category])
  @@index([fetchedAt])
  @@index([isPickedAt])
  @@index([translated])
}

model Category {
  id      String   @id @default(cuid())
  name    String   @unique
  order   Int      @default(0)
  enabled Boolean  @default(true)
  sources Source[]
}

model Source {
  id         String   @id @default(cuid())
  name       String
  url        String   @unique
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  isChinese  Boolean  @default(false)
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
}
